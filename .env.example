# Copy this file to `.env` and fill in your key. `.env` is gitignored and is
# ONLY read by the Node generation scripts — it is never bundled into the
# browser / client code.

# Which generator to use for `npm run generate-creatures` / `generate-assets`:
#   procedural (default, free, offline)  |  meshy  |  tripo
CREATURE_PROVIDER=meshy

# Meshy.ai API key — https://www.meshy.ai/  (Settings -> API)
MESHY_API_KEY=

# Meshy quality: "preview" (fast, cheaper, untextured) or "refine" (textured, pricier)
MESHY_MODE=preview

# Tripo (alternative provider)
# TRIPO_API_KEY=
